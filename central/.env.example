# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin API (Bearer token for /api/raspnvr/admin/*)
RASPNVR_ADMIN_KEY=change-me-admin-key

# Optional: Cloudflare Access (Phase D)
# CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
# CF_ACCESS_AUD=application-aud-tag

# Storage bucket for recordings
RASPNVR_STORAGE_BUCKET=raspnvr-recordings

# Cron secret (Vercel Cron)
CRON_SECRET=change-me-cron-secret
